<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- TREE VIEW -->
    <record id="view_leave_request_tree" model="ir.ui.view">
        <field name="name">leave.request.tree</field>
        <field name="model">leave.request</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="employee_name"/>
                <field name="leave_type"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="total_days"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_leave_request_form" model="ir.ui.view">
        <field name="name">leave.request.form</field>
        <field name="model">leave.request</field>
        <field name="arch" type="xml">
            <form>

                <header>
                    <button name="action_submit" type="object" string="Submit"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <button name="action_approve" type="object" string="Approve"
                            class="btn-success"
                            invisible="state != 'submitted'"/>

                    <button name="action_reject" type="object" string="Reject"
                            class="btn-danger"
                            invisible="state != 'submitted'"/>

                    <button name="action_reset_draft" type="object" string="Reset"
                            class="btn-secondary"
                            invisible="state == 'draft'"/>

                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,rejected"/>
                </header>

                <sheet>

                    <group>
                        <field name="name" readonly="1"/>
                        <field name="employee_name"/>
                        <field name="leave_type"/>
                        <field name="approver_name"/>
                        <field name="state" readonly="1"/>
                    </group>

                    <group>
                        <field name="start_date"/>
                        <field name="end_date"/>
                        <field name="total_days" readonly="1"/>
                    </group>

                    <group>
                        <field name="reason"/>
                    </group>

                </sheet>

            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_leave_request" model="ir.actions.act_window">
        <field name="name">Leave Requests</field>
        <field name="res_model">leave.request</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- MENUS -->
    <menuitem id="menu_leave_root" name="Leave Management"/>
    <menuitem id="menu_leave_request"
              name="Leave Requests"
              parent="menu_leave_root"
              action="action_leave_request"/>
</odoo>