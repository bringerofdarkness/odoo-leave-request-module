<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Category -->
    <record id="module_category_leave_management" model="ir.module.category">
        <field name="name">Leave Management</field>
        <field name="description">Helps you manage employee leave requests.</field>
        <field name="sequence">20</field>
    </record>

    <!-- Groups -->
    <record id="group_leave_employee" model="res.groups">
        <field name="name">Leave Employee</field>
        <field name="category_id" ref="module_category_leave_management"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_leave_manager" model="res.groups">
        <field name="name">Leave Manager</field>
        <field name="category_id" ref="module_category_leave_management"/>
        <field name="implied_ids" eval="[(4, ref('group_leave_employee'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <!-- Record Rules -->
    <!-- Employee Rule: Can see only their own requests or requests where they are the approver -->
    <record id="rule_leave_request_employee" model="ir.rule">
        <field name="name">Leave Request: Employee Rule</field>
        <field name="model_id" ref="model_leave_request"/>
        <field name="groups" eval="[(4, ref('group_leave_employee'))]"/>
        <field name="domain_force">['|', ('employee_id.user_id', '=', user.id), ('approver_id.user_id', '=', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Manager Rule: Can see all requests -->
    <record id="rule_leave_request_manager" model="ir.rule">
        <field name="name">Leave Request: Manager Rule</field>
        <field name="model_id" ref="model_leave_request"/>
        <field name="groups" eval="[(4, ref('group_leave_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
</odoo>
